# ================================
# AI Cybersecurity Assistant - Production ENV Template
# Copy this file to project root as .env and fill real values.
# ================================

# Core security
FLASK_SECRET_KEY=replace_with_64_char_random_secret
SESSION_COOKIE_SECURE=1
ENFORCE_HTTPS=1
TRUST_PROXY_HEADERS=1
SESSION_TTL_HOURS=12
MIN_PASSWORD_LENGTH=12

# Optional default admin
DEFAULT_ADMIN_PASSWORD=

# AI module
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_MODEL=gpt-5.4
OPENAI_TIMEOUT_SECONDS=8
OPENAI_FAIL_CACHE_SECONDS=180
USE_OLLAMA_CHATBOT=0
OLLAMA_MODEL=llama3
OLLAMA_URL=http://localhost:11434/api/generate

# Breach checker (HIBP)
HIBP_API_KEY=replace_with_hibp_api_key

# Google OAuth login
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Google AdSense (optional but needed for ads earning)
ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx

# Face intel
FACECHECK_API_TOKEN=replace_with_facecheck_api_token
# 1 = demo mode, 0 = live search mode
FACECHECK_DEMO=0

# Pakistan bank receiving details (for bank-transfer payment flow)
PK_BANK_NAME=United Bank Limited (UBL)
PK_ACCOUNT_TITLE=replace_with_your_account_title
PK_ACCOUNT_NUMBER=replace_with_account_number
PK_IBAN=replace_with_iban

# Keep 0 in production. 1 is demo auto-credit mode.
BANK_TRANSFER_AUTO_APPROVE=0
ENABLE_SIMULATED_PAYMENTS=0
OTP_DEBUG_MODE=0

# Rate limits / auth protection
API_RATE_LIMIT=120
API_RATE_WINDOW=60
AUTH_RATE_LIMIT=20
AUTH_RATE_WINDOW=600
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_SECONDS=900
