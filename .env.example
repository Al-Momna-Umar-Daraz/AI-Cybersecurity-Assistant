FLASK_SECRET_KEY=replace_with_a_long_random_secret
SESSION_COOKIE_SECURE=1
ENFORCE_HTTPS=1
TRUST_PROXY_HEADERS=0
SESSION_TTL_HOURS=12
MIN_PASSWORD_LENGTH=12

DEFAULT_ADMIN_PASSWORD=replace_if_you_need_default_admin

OPENAI_API_KEY=replace_with_openai_key
OPENAI_MODEL=gpt-5.4
OPENAI_TIMEOUT_SECONDS=8
OPENAI_FAIL_CACHE_SECONDS=180
USE_OLLAMA_CHATBOT=0
OLLAMA_MODEL=llama3
OLLAMA_URL=http://localhost:11434/api/generate

HIBP_API_KEY=replace_with_hibp_key

GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=replace_with_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret

ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx

FACECHECK_API_TOKEN=replace_with_facecheck_api_token
FACECHECK_DEMO=1

UBL_BANK_NAME=United Bank Limited (UBL)
UBL_ACCOUNT_TITLE=replace_with_your_account_title
UBL_ACCOUNT_NUMBER=replace_with_account_number
UBL_IBAN=replace_with_iban

PK_BANK_NAME=United Bank Limited (UBL)
PK_ACCOUNT_TITLE=replace_with_your_account_title
PK_ACCOUNT_NUMBER=replace_with_account_number
PK_IBAN=replace_with_iban
BANK_TRANSFER_AUTO_APPROVE=0
ENABLE_SIMULATED_PAYMENTS=0
OTP_DEBUG_MODE=0

API_RATE_LIMIT=120
API_RATE_WINDOW=60
AUTH_RATE_LIMIT=20
AUTH_RATE_WINDOW=600
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_SECONDS=900
